# ─────────────────────────────────────────────
# RAG Layer 1 Demo — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── Postgres ──────────────────────────────────
POSTGRES_USER=rag
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=rag_layer1
DATABASE_URL=postgresql://rag:ragpassword@localhost:5432/rag_layer1

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────
# CHANGE THIS in production — generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Environment ───────────────────────────────
# dev | prod
ENVIRONMENT=dev

# ── Embedding Provider ────────────────────────
# "mock" (free, random vectors) or "gemini" (requires GOOGLE_API_KEY)
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768
EMBEDDING_BATCH_SIZE=256

# Required only when EMBEDDING_PROVIDER=gemini
GOOGLE_API_KEY=

# ── File Storage ──────────────────────────────
# "local" or "s3" (s3 not implemented in V1)
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# ── Upload Limits ─────────────────────────────
MAX_FILE_SIZE_MB=25
MAX_FILES_PER_PROJECT=50

# ── Ports (for docker-compose) ────────────────
DB_PORT=5432
REDIS_PORT=6379
API_PORT=8000
WEB_PORT=3000
