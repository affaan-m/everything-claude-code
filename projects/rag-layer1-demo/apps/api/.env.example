# ──────────────────────────────────────────────────────────────────────────────
# RAG Layer 1 — API Environment Template
# Copy this file:  cp .env.example .env
# Then edit .env — never commit .env itself.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://rag:ragpassword@localhost:5432/rag_layer1

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Restrict in production, e.g. ALLOWED_ORIGINS=https://app.example.com
ALLOWED_ORIGINS=http://localhost:3000

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=dev

# ── Embedding Provider ────────────────────────────────────────────────────────
# mock | gemini
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768
EMBEDDING_BATCH_SIZE=256
# Required when EMBEDDING_PROVIDER=gemini
GOOGLE_API_KEY=

# ── File Storage ──────────────────────────────────────────────────────────────
# local | s3
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# ── S3 / S3-Compatible Storage ────────────────────────────────────────────────
# Required only when STORAGE_PROVIDER=s3.
# For local MinIO:  AWS_ENDPOINT_URL=http://localhost:9000
# For LocalStack:   AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name
AWS_ENDPOINT_URL=
AWS_S3_KEY_PREFIX=uploads

# ── Upload Limits ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=25
MAX_FILES_PER_PROJECT=50
