# ──────────────────────────────────────────────────────────────────────────────
# RAG Layer 1 — Web Environment Template
# Next.js automatically loads .env.local (gitignored).
# Copy this file:  cp .env.local.example .env.local
# Then edit .env.local — never commit .env.local itself.
# ──────────────────────────────────────────────────────────────────────────────

# ── API Connection ────────────────────────────────────────────────────────────
# Base URL of the FastAPI backend, reachable from the browser.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Environment ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_ENV=development
